{
  "name": "LLM Ticket Enhancer",
  "description": "Enhance Jira tickets using local LLM",
  "key": "nowtech-llm-ticket-enhancer",
  "baseUrl": "http://86.101.103.229:5000",
  "vendor": {
    "name": "NowTechnolgies",
    "url": "https://nowtech.hu"
  },
  "authentication": {
    "type": "jwt"
  },
  "lifecycle": {
    "installed": "/installed",
    "uninstalled": "/uninstalled"
